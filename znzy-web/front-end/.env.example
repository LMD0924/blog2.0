# OpenAI API 配置
# 请将此文件复制为 .env.local 并填入您的实际API密钥

# OpenAI API密钥
VITE_OPENAI_API_KEY=sk-xxx

# OpenAI API基础URL (可选，默认为 https://api.openai.com/v1)
# VITE_OPENAI_API_BASE_URL=https://api.openai.com/v1

# 默认使用的模型 (可选)
# VITE_OPENAI_DEFAULT_MODEL=gpt-3.5-turbo

# 代理设置 (如果需要)
# VITE_PROXY_URL=http://localhost:8080